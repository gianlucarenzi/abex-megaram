# ecp5_25k.lpf — Pin constraints for Lattice ECP5-25k (e.g. ULX3S / custom PCB)
#
# IMPORTANT: These are TEMPLATE assignments.  Assign each signal to the
# actual GPIO pin connected on your PCB before synthesising.
# Consult the ECP5-25k datasheet and your board schematic.
#
# All Atari bus signals operate at 5V; use 5V↔3.3V level-shifters
# (e.g. TXS0108B) between the Atari and the FPGA IOs.
#
# Toolchain:
#   yosys -p "synth_ecp5 -top top -json top.json" \
#         rtl/top.v rtl/portb_emu.v rtl/bank_switch.v
#   nextpnr-ecp5 --25k --package CABGA256 \
#                --json top.json --lpf constraints/ecp5_25k.lpf \
#                --textcfg top.config
#   ecppack top.config top.bit
#   openocd -f <board.cfg> -c "svf top.svf; shutdown"   # or fujprog / ecpdap

# ── Atari bus ──────────────────────────────────────────────────────────────
# PHI2: route to a PCLKT/SCLKT pin for the clock tree.
LOCATE COMP "phi2"         SITE "L16";  # TODO: use a clock-capable pin

LOCATE COMP "addr[0]"      SITE "A2";   # TODO
LOCATE COMP "addr[1]"      SITE "A3";   # TODO
LOCATE COMP "addr[2]"      SITE "A4";   # TODO
LOCATE COMP "addr[3]"      SITE "A5";   # TODO
LOCATE COMP "addr[4]"      SITE "B2";   # TODO
LOCATE COMP "addr[5]"      SITE "B3";   # TODO
LOCATE COMP "addr[6]"      SITE "B4";   # TODO
LOCATE COMP "addr[7]"      SITE "B5";   # TODO
LOCATE COMP "addr[8]"      SITE "C2";   # TODO
LOCATE COMP "addr[9]"      SITE "C3";   # TODO
LOCATE COMP "addr[10]"     SITE "C4";   # TODO
LOCATE COMP "addr[11]"     SITE "C5";   # TODO
LOCATE COMP "addr[12]"     SITE "D1";   # TODO
LOCATE COMP "addr[13]"     SITE "D2";   # TODO
LOCATE COMP "addr[14]"     SITE "D3";   # TODO
LOCATE COMP "addr[15]"     SITE "D4";   # TODO

LOCATE COMP "atari_data[0]" SITE "E1";  # TODO
LOCATE COMP "atari_data[1]" SITE "E2";  # TODO
LOCATE COMP "atari_data[2]" SITE "E3";  # TODO
LOCATE COMP "atari_data[3]" SITE "E4";  # TODO
LOCATE COMP "atari_data[4]" SITE "F1";  # TODO
LOCATE COMP "atari_data[5]" SITE "F2";  # TODO
LOCATE COMP "atari_data[6]" SITE "F3";  # TODO
LOCATE COMP "atari_data[7]" SITE "F4";  # TODO

LOCATE COMP "rw"           SITE "G1";   # TODO

# IO standard for all Atari bus signals (3.3V via level-shifter)
IOBUF PORT "phi2"          IO_TYPE=LVCMOS33;
IOBUF PORT "rw"            IO_TYPE=LVCMOS33;

# ── DIP switches ───────────────────────────────────────────────────────────
LOCATE COMP "conf[0]"      SITE "H1";   # CONF0 — TODO
LOCATE COMP "conf[1]"      SITE "H2";   # CONF1 — TODO
LOCATE COMP "conf[2]"      SITE "H3";   # CONF2 — TODO

# ── Atari control outputs ──────────────────────────────────────────────────
LOCATE COMP "extsel_n"     SITE "J1";   # EXTSEL_N — TODO

# ── External SRAM ──────────────────────────────────────────────────────────
LOCATE COMP "sram_addr[0]"  SITE "K1";  # TODO
LOCATE COMP "sram_addr[1]"  SITE "K2";  # TODO
LOCATE COMP "sram_addr[2]"  SITE "K3";  # TODO
LOCATE COMP "sram_addr[3]"  SITE "L1";  # TODO
LOCATE COMP "sram_addr[4]"  SITE "L2";  # TODO
LOCATE COMP "sram_addr[5]"  SITE "L3";  # TODO
LOCATE COMP "sram_addr[6]"  SITE "M1";  # TODO
LOCATE COMP "sram_addr[7]"  SITE "M2";  # TODO
LOCATE COMP "sram_addr[8]"  SITE "M3";  # TODO
LOCATE COMP "sram_addr[9]"  SITE "N1";  # TODO
LOCATE COMP "sram_addr[10]" SITE "N2";  # TODO
LOCATE COMP "sram_addr[11]" SITE "N3";  # TODO
LOCATE COMP "sram_addr[12]" SITE "P1";  # TODO
LOCATE COMP "sram_addr[13]" SITE "P2";  # TODO
LOCATE COMP "sram_addr[14]" SITE "P3";  # TODO  (bank bit 0)
LOCATE COMP "sram_addr[15]" SITE "R1";  # TODO  (bank bit 1)
LOCATE COMP "sram_addr[16]" SITE "R2";  # TODO  (bank bit 2)
LOCATE COMP "sram_addr[17]" SITE "R3";  # TODO  (bank bit 3)
LOCATE COMP "sram_addr[18]" SITE "T1";  # TODO  (bank bit 4)
LOCATE COMP "sram_addr[19]" SITE "T2";  # TODO  (bank bit 5 — 1M SRAM only)

# NOTE (Topology B): sram_data[7:0] is NOT a FPGA port.
# The SRAM data bus is wired directly to the Atari data bus on the PCB
# via bidirectional level-shifters (e.g. TXS0108B).

LOCATE COMP "sram_ce_n"    SITE "W3";   # TODO
LOCATE COMP "sram_oe_n"    SITE "Y1";   # TODO
LOCATE COMP "sram_we_n"    SITE "Y2";   # TODO
