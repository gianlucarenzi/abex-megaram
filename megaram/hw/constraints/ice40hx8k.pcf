# ice40hx8k.pcf — Pin constraints for iCE40HX-8K (e.g. iCEblink40 / custom PCB)
#
# IMPORTANT: These are TEMPLATE assignments.  Assign each signal to the
# actual GPIO pin connected on your PCB before synthesising.
# Verify with the board schematic and the iCE40 HX8K datasheet.
#
# All Atari bus signals operate at 5V; use 5V↔3.3V level-shifters
# (e.g. TXS0108E or SN74LVC8T245) between the Atari and the FPGA IOs.
#
# Toolchain:
#   yosys -p "synth_ice40 -top top -json top.json" \
#         rtl/top.v rtl/portb_emu.v rtl/bank_switch.v
#   nextpnr-ice40 --hx8k --package ct256 \
#                 --json top.json --pcf constraints/ice40hx8k.pcf \
#                 --asc top.asc
#   icepack top.asc top.bin
#   iceprog top.bin

# ── Atari bus ──────────────────────────────────────────────────────────────
# PHI2 should be routed to a dedicated clock pin (e.g. J3 on HX8K-B-EVN)
# so nextpnr can use a global clock buffer.
set_io phi2        J3    # TODO: assign to clock-capable IO

set_io addr[0]     A1    # TODO
set_io addr[1]     A2    # TODO
set_io addr[2]     B1    # TODO
set_io addr[3]     B2    # TODO
set_io addr[4]     C1    # TODO
set_io addr[5]     C2    # TODO
set_io addr[6]     D1    # TODO
set_io addr[7]     D2    # TODO
set_io addr[8]     E1    # TODO
set_io addr[9]     E2    # TODO
set_io addr[10]    F1    # TODO
set_io addr[11]    F2    # TODO
set_io addr[12]    G1    # TODO
set_io addr[13]    G2    # TODO
set_io addr[14]    H1    # TODO
set_io addr[15]    H2    # TODO

set_io atari_data[0]  J1   # TODO
set_io atari_data[1]  J2   # TODO
set_io atari_data[2]  K1   # TODO
set_io atari_data[3]  K2   # TODO
set_io atari_data[4]  L1   # TODO
set_io atari_data[5]  L2   # TODO
set_io atari_data[6]  M1   # TODO
set_io atari_data[7]  M2   # TODO

set_io rw          N1    # TODO

# ── DIP switches (expansion type) ─────────────────────────────────────────
set_io conf[0]     P1    # CONF0
set_io conf[1]     P2    # CONF1
set_io conf[2]     R1    # CONF2

# ── Atari control outputs ──────────────────────────────────────────────────
set_io extsel_n    R2    # EXTSEL_N (nEXSEL): disable Atari internal RAM

# ── External SRAM (e.g. AS7C38096A-10TIN  512K×8, or 1M×8 for 1088K) ────
# Address bus
set_io sram_addr[0]   T1   # TODO
set_io sram_addr[1]   T2   # TODO
set_io sram_addr[2]   U1   # TODO
set_io sram_addr[3]   U2   # TODO
set_io sram_addr[4]   V1   # TODO
set_io sram_addr[5]   V2   # TODO
set_io sram_addr[6]   W1   # TODO
set_io sram_addr[7]   W2   # TODO
set_io sram_addr[8]   AA1  # TODO
set_io sram_addr[9]   AA2  # TODO
set_io sram_addr[10]  AB1  # TODO
set_io sram_addr[11]  AB2  # TODO
set_io sram_addr[12]  AC1  # TODO
set_io sram_addr[13]  AC2  # TODO
set_io sram_addr[14]  AD1  # TODO  (bank bit 0)
set_io sram_addr[15]  AD2  # TODO  (bank bit 1)
set_io sram_addr[16]  AE1  # TODO  (bank bit 2)
set_io sram_addr[17]  AE2  # TODO  (bank bit 3)
set_io sram_addr[18]  AF1  # TODO  (bank bit 4)
set_io sram_addr[19]  AF2  # TODO  (bank bit 5 — only for 1M SRAM/1088K)

# Data bus
set_io sram_data[0]   B3   # TODO
set_io sram_data[1]   C3   # TODO
set_io sram_data[2]   D3   # TODO
set_io sram_data[3]   E3   # TODO
set_io sram_data[4]   F3   # TODO
set_io sram_data[5]   G3   # TODO
set_io sram_data[6]   H3   # TODO
set_io sram_data[7]   J3   # TODO

# Control
set_io sram_ce_n   K3    # TODO
set_io sram_oe_n   L3    # TODO
set_io sram_we_n   M3    # TODO
